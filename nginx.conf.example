server {
    listen 80;
    server_name hunnycoders.com www.hunnycoders.com 123.456.78.90; # Replace the IP with your VPS IP if you use IP access

    # Frontend configuration (assuming built React app)
    location / {
        root /var/www/honeycoders/dist; # Path to your built frontend files
        try_files $uri $uri/ /index.html;
        index index.html;
    }

    # Backend API configuration
    location /api/ {
        proxy_pass http://127.0.0.1:4000; # Points to the backend Express server
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        
        # Real IP headers
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Uploads (Static files served by backend)
    location /uploads/ {
        proxy_pass http://127.0.0.1:4000/uploads/;
        proxy_set_header Host $host;
        expires 30d;
    }
}
